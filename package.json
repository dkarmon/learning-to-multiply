    "firebase:emulators": "firebase emulators:start --only auth,firestore --project demo-learning-multiply",
    "dev:emulators": "firebase emulators:start --only auth,firestore --project demo-learning-multiply & vite --mode emulators"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
